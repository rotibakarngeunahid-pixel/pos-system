# ══════════════════════════════════════════════════════════════════
# .env.example — Salin file ini menjadi .env, isi dengan nilai asli
# JANGAN commit .env ke Git. File .env sudah ada di .gitignore.
# ══════════════════════════════════════════════════════════════════

# Database MySQL (cPanel)
DB_HOST=localhost
DB_NAME=nama_database_anda
DB_USER=username_database_anda
DB_PASS=password_database_anda

# API Key (buat string acak 32+ karakter, harus sama dengan yang dikonfig di server)
API_SECRET_KEY=ganti_dengan_string_acak_minimal_32_karakter

# URL domain frontend (tanpa trailing slash)
SITE_URL=https://pos.domainanda.com

# URL publik untuk file upload (domain tempat folder /uploads berada).
# Kosongkan jika folder /uploads berada di host yang sama dengan api/upload.php.
UPLOADS_BASE_URL=https://api.domainanda.com

# ── Integrasi POS → Inventori (sinkronisasi transfer & stok keluar) ──────────
# URL BASIS API Inventori (Next.js/Vercel), tanpa trailing slash:
INVENTORY_API_URL=https://inventory.rotibakarngeunah.my.id/api
# X-API-Key Inventori dengan scope 'integration:write' (buat di tabel api_keys Inventori).
# Kosongkan keduanya untuk menonaktifkan sinkronisasi (transaksi POS tetap jalan).
INVENTORY_API_KEY=ganti_dengan_api_key_inventori
