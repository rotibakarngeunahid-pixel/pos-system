# Folder ini hanya boleh berisi file gambar/pdf — tidak ada eksekusi PHP
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

Options -Indexes -ExecCGI

# Izinkan akses langsung ke bukti setoran.
<FilesMatch "\.(jpg|jpeg|png|pdf)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Allow from all
    </IfModule>
</FilesMatch>

# Tolak semua file selain gambar dan PDF
<FilesMatch "^(?!.*\.(jpg|jpeg|png|pdf)$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>
